# Casana · apps/api — variables de entorno (NO commitear el .env real)
# Los secretos reales viven en Secret Manager (GCP).

# Base de datos (Prisma / PostgreSQL). Con docker-compose local:
DATABASE_URL=postgresql://casana:casana@localhost:5432/casana?schema=public

# Stripe (ADR-0002)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price recurrente mensual "Cuota Casana por trabajador" (creado en el dashboard de Stripe)
STRIPE_PRICE_CUOTA_MENSUAL=price_xxx

# OCR de INE con Document AI (opcional; si no se define, se usa el OCR mock)
# GCP_PROJECT=casana-prod
# GCP_LOCATION=us
# GCP_DOCUMENTAI_PROCESSOR=xxxxxxxxxxxx

# imss-gateway (RPA). Sin IMSS_RPA_ENABLED=true se usa el adaptador mock.
# Requiere: npx playwright install chromium
# IMSS_RPA_ENABLED=true
# IMSS_PORTAL_URL=https://adodigital.imss.gob.mx/pth/
# IMSS_RPA_HEADLESS=true
